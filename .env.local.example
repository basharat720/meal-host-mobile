# Copy this file to .env.local and fill in your values.
# Use your Mac's LAN IP for BACKEND_API_URL so the phone can reach it.
# Find your LAN IP: ipconfig getifaddr en0

EXPO_PUBLIC_BACKEND_API_URL=http://192.168.x.x:8000

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — Google Sign-In requires a custom dev build (not Expo Go)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional — for image uploads via Cloudinary
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
